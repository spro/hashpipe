{
  function foldInfix(head, tail) {
    return tail.reduce(function(acc, t) {
      return {op: t.op, left: acc, right: t.right};
    }, head);
  }
}

start
  = pipelines

// @ parser
// ~~~~~~~~

letter = [a-zA-Z0-9_~/-]
space = [ \n\t\r]*
hspace = [ \t\r]*
comma = space "," space
dot = space "." space { return 'get'; }
col = space ":" space { return 'map'; }
open_bracket = space "[" space
close_bracket = space "]" space
at = space "@" space

at_word = ls:letter+ { return ls.join(''); }

at_array = open_bracket
    values:(
        head:at_expression
        tail:(comma t:at_expression { return t; })*
        { return [head].concat(tail); }
    )
    close_bracket { return values; }

okv =
    k:at_word col v:(sub_cmd / at_expression) { return {key: k, val: v}; }
    / k:sub_cmd col v:(sub_cmd / at_expression) { return {key: [k], val: v}; }
    / k:at_word { return {key: k, val: [{get: k}]}; }

at_obj = "{" space ss:(okv comma?)+ space "}" {
    ss = ss.map(function(sp) { return sp[0]; });
    return {obj: ss};
}

at_quoted = q:quoted_literal { return q.quoted.join(''); }
at_wild = "*" { return "*"; }

section = at_obj / at_array / at_quoted / at_wild / at_word

do_sub = (s:dot t:sub_cmd { return t; })
do_sub_ = (s:dot? t:sub_cmd { return t; })
do_get = (s:dot t:section { return {get: t}; })
do_get_ = (s:dot? t:section { return {get: t}; }) / (s:dot { return {get: '.'}; })
do_map = (s:col+ t:section { return {map: t, depth:s.length}; })
do_section = do_get / do_map

at_expression =
    space
    head:(do_get_/do_sub_/do_map)
    tail:do_section*
    hspace
    {
        return [head].concat(tail);
    }

// Pipeline parser
// ~~~~~~~~~~~~~~~

// Pipe operators are one generic rule: the suffix char selects the
// operator and the runtime registry (pipeline.ts) decides what it means.
// Unknown suffixes parse but fail loudly at runtime.
pipe_op = space "|" suffix:[|=?&^~]? space { return "|" + (suffix || ""); }
// Trailing whitespace after a closing quote stays horizontal so a
// newline can still act as a statement separator
squote = hspace ['] hspace
dquote = hspace ["] hspace
squote_ = hspace [']
_squote = ['] hspace
dquote_ = hspace ["]
_dquote = ["] hspace

decimal = "." ds:[0-9]+ { var n = Number(ds.join('')); return n/Math.pow(10.0, ds.length); }
number = s:"-"? ds:[0-9]+ dec:decimal?
    { var n = Number(ds.join('')); n += dec || 0; if (s) n = n*-1; return n; }
ok_char = letter / [=:/.#%!?+*%^&]
// One escape rule covers every metacharacter, present and future.
// \$ keeps its backslash so parseArgs never treats it as a variable
// (it strips the backslash after substitution). letter@letter lets
// emails and handles keep a bare @ mid-word.
mid_at = l1:letter "@" l2:letter { return l1+'@'+l2; }
escd_char = mid_at
    / "\\$" { return "\\$"; }
    / "\\" c:. { return c; }
letter_word = ls:letter+ { return ls.join(''); }
var_word = "${" w:letter_word "}" { return '$' + w; }
    / "$" w:letter_word { return '$' + w; }
    / "$!"
// Inside words the braced form keeps its braces so ${file}_v2 can be
// spliced without eating the suffix; parseArgs resolves it.
var_ref = "${" w:letter_word "}" { return '${' + w + '}'; }
    / var_word
cmd_char = escd_char / ok_char / var_ref
cmd_word = cs:cmd_char+ { return cs.join('').trim(); }
squoted_cmd = squote cmd:cmd squote { return {quoted: cmd}; }
dquoted_cmd = dquote cmd:cmd dquote { return {quoted: cmd}; }
quoted_cmd = squoted_cmd / dquoted_cmd
squoted_literal = squote_ ls:("\\n" { return '\n'; } / escd_char / [^'] )* _squote { return {quoted: [ls.join('')] }; }
dquoted_literal = dquote_ ls:("\\n" { return '\n'; } / escd_char / [^"] )* _dquote { return {quoted: [ls.join('')] }; }
quoted_literal = squoted_literal / dquoted_literal
valid_key = letter_word/quoted_literal
quoted_phrase = quoted_literal / quoted_cmd
cmd_phrase = quoted_phrase / cmd_word / lambda / sub_cmd

// Lambda literals: a pipeline block {| body }, optionally naming its input:
// { $name | body }. Names bind arguments positionally; a name with no
// matching argument receives the piped input. The $ sigil is required, so
// bare words are never names and {| trim | upper } stays a two-stage body.
lambda =
    "{" space params:lambda_params? "|" space body:pipelines space "}"
    { return {fn: body, params: params || [], src: text()}; }

lambda_params =
    head:param_name tail:(space1 w:param_name { return w; })* space
    { return [head].concat(tail); }

param_name = "$" w:letter_word { return w; }

bool_word = "true" / "false"

cmd = obj_cmd / list_cmd /
      head:cmd_phrase
      tail:(hspace c:cmd_phrase { return c; })*
      { return [head].concat(tail); }

// Infix expressions: $n * 7, 2 + 3 * 4, $(@ age) > 30
// Operands are values (numbers, strings, $vars, sub-pipes, parens) — never
// bare command words — so prefix commands like `* 7` and words like
// `dog-years` are unaffected.

space1 = [ \n\t\r]+
comp_op = "<=" / ">=" / "==" / "!=" / "<" / ">"
add_op = "+" / "-"
mul_op = "*" / "/" / "%"

infix_at =
    e:infix_expr &{ return e.op != null; }
    atexp:(at atexp:at_expression { return atexp; })?
    { return {expr: e, at: atexp}; }

infix_expr = comparison

comparison =
    head:additive tail:(space op:comp_op space r:additive { return {op: op, right: r}; })*
    { return foldInfix(head, tail); }

additive =
    head:multiplicative tail:(space op:add_op space r:multiplicative { return {op: op, right: r}; })*
    { return foldInfix(head, tail); }

multiplicative =
    head:infix_operand tail:(space op:mul_op space r:infix_operand { return {op: op, right: r}; })*
    { return foldInfix(head, tail); }

infix_operand =
    number:number { return {val: number}; }
    / v:var_word { return {var: v}; }
    / q:quoted_literal { return {val: q.quoted.join('')}; }
    / sub_cmd
    / "(" space e:infix_expr space ")" { return e; }

cmd_at =
    infix_at
    / cmd:cmd
    atexp:(at atexp:at_expression { return atexp; })?
    { return {cmd: cmd, at: atexp}; }
    / atexp:(at atexp:at_expression { return atexp; })
    { return {at: atexp}; }

var_exp =
    var_word:var_word
    atexp:(at atexp:at_expression { return atexp; })?
    { return {var: var_word, at: atexp}; }

start_cmd =
    infix:infix_at { infix.type = '|'; return infix; }
    / var_exp
    / number:number { return {val: number}; }
    / quoted:quoted_phrase { return {val: quoted}; }
    / bool:bool_word !letter { return {val: bool == 'true'}; }
    / "null" !letter { return {val: null}; }
    / lambda:lambda { return {val: lambda}; }
    / cmd_at:cmd_at { cmd_at.type = '|'; return cmd_at; }
piped_cmd =
    op:pipe_op cmd_at:cmd_at
    { cmd_at.type = op; return cmd_at; }

cmd_section = start_cmd / piped_cmd

sub_cmd =
    "$(" pipelines:pipelines ")"
    { return {sub:pipelines}; }
    / obj_cmd:obj_cmd
    { return {sub: [[{cmd:obj_cmd}]]}; }
    / list_cmd:list_cmd
    { return {sub: [[{cmd:list_cmd}]]}; }

pipeline =
    aliasing / setting /
    space
    head:cmd_section
    tail:cmd_section*
    hspace
    { if (head) return [head].concat(tail); else return tail; }

// Statements are separated by ';' or newline. A '#' at statement
// position starts a comment (to end of line or ';'); '#' mid-word is
// literal. Pipe continuations still span lines because pipe_op and
// at-expressions consume newlines themselves.
stmt_sep = hspace (";" / "\n") space
comment = hspace "#" [^\n;]* { return null; }

statement =
    comment
    / pipeline
    / hspace { return null; }

pipelines =
    head:statement
    tail:(stmt_sep s:statement { return s; })*
    {
        var stmts = [head].concat(tail).filter(function(s) { return s != null; });
        if (!stmts.length) return [[{cmd: ['id']}]];
        return stmts;
    }

aliasing =
    space "alias" space alias:letter_word space "=" space body:alias_body
    { return [{cmd: ['alias', alias, body]}]; }

// An alias body is a single parsed pipeline (stops at ';'), carried as an
// unevaluated lambda token so definition-time substitution never happens.
alias_body =
    body:pipeline
    { return {fn: [body], params: [], src: text().trim()}; }

// `!"="` keeps `$x == y` an equality comparison rather than an assignment
setup = var_word:var_word space "=" !"=" space { return var_word; }

setting =
    space set:setup pipeline:pipeline
    { return [{cmd: ['set', set.slice(1), {sub: [pipeline]}]}]; }
    / space set:setup
    { return [{cmd: ['set', set.slice(1)]}]; }

kv =
    k:valid_key col v:pipeline { return {key: k, val: v}; }

obj_cmd = 
    "{" space "}" { return ['obj']; }
    / "{" space head:kv tail:(comma kv)* space "}"
    {
        var kvs = [head].concat(tail.map(function(t) { return t[1]; }));
        var obj_cmd = ['obj'];
        for (var i in kvs) {
            var kv = kvs[i];
            obj_cmd.push(kv.key);
            obj_cmd.push({sub:[kv.val]});
        }
        return obj_cmd;
    }

list_cmd = "[" space head:start_cmd tail:(comma start_cmd)* space "]"
    {
        var items = [head].concat(tail.map(function(t) { return t[1]; }));
        items = items.map(function(item) { return {sub: [[item]]}; });
        var list_cmd = ['list'].concat(items);
        return list_cmd;
    }
